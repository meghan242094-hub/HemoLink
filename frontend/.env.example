# Backend API URL
# For production, set this to your Render backend URL
# Example: https://hemolink-backend.onrender.com
REACT_APP_API_URL=http://localhost:5000

# Socket.IO URL
# For production, set this to your Render backend URL
# Example: https://hemolink-backend.onrender.com
REACT_APP_SOCKET_URL=http://localhost:5000
