# MongoDB Connection String
# For production, use MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/hemolink

# JWT Secret Key
# IMPORTANT: Use a strong, random secret key in production
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
# Render will set this automatically, but you can override if needed
PORT=5000

# Frontend URL (for CORS)
# For production, set this to your Vercel frontend URL
# Example: https://hemolink-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
